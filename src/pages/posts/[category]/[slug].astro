---
import { getCollection } from 'astro:content';
import ads from '../../../content/ads/index.json';
import settings from '../../../content/settings/index.json';
import '../../../styles/global.css';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { 
      category: post.data.category,
      slug: post.slug 
    },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const dbCategories = await getCollection('categories');
const getCategoryName = (slug: string) => {
  const cat = dbCategories.find(c => c.id === slug);
  return cat ? cat.data.name : slug;
};

const categoryName = getCategoryName(post.data.category);

// Get related posts from the same category (excluding current)
const allPosts = await getCollection('posts');
const relatedPosts = allPosts
  .filter(p => p.data.category === post.data.category && p.slug !== post.slug)
  .slice(0, 3);

// Date formatter
const formatDate = (date: Date) => {
  return date.toLocaleDateString('ru-RU', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
};

// Video URL converter to embed version
function getEmbedUrl(url: string | undefined): string | null {
  if (!url) return null;
  
  try {
    if (url.includes('youtube.com') || url.includes('youtu.be')) {
      let videoId = '';
      if (url.includes('youtu.be/')) {
        videoId = url.split('youtu.be/')[1].split(/[?#]/)[0];
      } else if (url.includes('v=')) {
        videoId = url.split('v=')[1].split(/[&#]/)[0];
      } else if (url.includes('embed/')) {
        return url;
      }
      return videoId ? `https://www.youtube.com/embed/${videoId}` : url;
    }
    
    if (url.includes('rutube.ru')) {
      if (url.includes('rutube.ru/play/embed/')) {
        return url;
      }
      const match = url.match(/rutube\.ru\/video\/([a-zA-Z0-9]+)/);
      if (match && match[1]) {
        return `https://rutube.ru/play/embed/${match[1]}`;
      }
      return url;
    }
    
    return url;
  } catch (e) {
    return url;
  }
}

const embedVideoUrl = getEmbedUrl(post.data.videoUrl);
---

<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{post.data.title} — {categoryName} — {settings.siteName}</title>
  <meta name="description" content={post.data.description}>
</head>
<body>

  <!-- Navigation -->
  <nav class="navbar">
    <div class="container navbar-inner">
      <a href="/" class="logo">
        {settings.siteName}
        <span class="logo-dot"></span>
      </a>
      <div class="nav-links">
        <a href="/" class="nav-link">Главная</a>
      </div>
    </div>
  </nav>

  <main class="container" style="margin-top: 2rem;">
    <!-- Breadcrumbs -->
    <nav class="breadcrumbs">
      <a href="/">Главная</a>
      <span class="breadcrumbs-separator">/</span>
      <a href={`/#${post.data.category}`}>{categoryName}</a>
      <span class="breadcrumbs-separator">/</span>
      <span style="color: var(--text-primary); font-weight: 500;">{post.data.title}</span>
    </nav>

    <!-- Two-column content layout -->
    <div class="article-layout">
      <!-- Left Column: Article Content -->
      <article>
        <!-- Article Header -->
        <header class="article-header" style="padding: 0 0 2rem;">
          <h1 class="article-title" style="margin: 0.5rem 0 1rem; line-height: 1.2;">{post.data.title}</h1>
          <div class="article-meta" style="border-bottom: 1px solid var(--border-color); padding-bottom: 1.5rem;">
            <span class={`badge badge-${post.data.category}`} style="margin-right: 1rem;">
              {categoryName}
            </span>
            <time datetime={post.data.date.toISOString()}>
              {formatDate(post.data.date)}
            </time>
          </div>
        </header>

        <!-- Article Cover -->
        {post.data.coverImage && (
          <div class="article-cover-container">
            <img src={post.data.coverImage} alt={post.data.title} class="article-cover-main" />
          </div>
        )}

        <!-- Article Body -->
        <section class="article-body">
          <Content />

          <!-- Article Ad Banner Area -->
          {(ads.showCustomBanner && ads.customBannerImage) ? (
            <div class="ad-container" style="margin: 3rem auto; text-align: center; max-width: 728px;">
              <a href={ads.customBannerLink || '#'} target="_blank" rel="noopener noreferrer" style="display: block;">
                <img src={ads.customBannerImage} alt="Реклама" style="width: 100%; height: auto; border-radius: var(--radius-sm); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm);" />
              </a>
            </div>
          ) : ads.yandexDirectArticle ? (
            <div class="ad-container" style="margin: 3rem auto; text-align: center; max-width: 728px; width: 100%; min-height: 90px;" set:html={ads.yandexDirectArticle}></div>
          ) : null}
          
          <!-- Video Player Section (if uploaded file is present) -->
          {post.data.videoFile && (
            <div class="video-section" style="margin-top: 3.5rem;">
              <h2 style="margin-bottom: 1.5rem;">Видео по теме:</h2>
              <div style="margin: 2rem 0;">
                <video
                  src={post.data.videoFile}
                  controls
                  style="width: 100%; border-radius: var(--radius-md); border: 1px solid var(--border-color); box-shadow: var(--shadow-lg), var(--glow-shadow);"
                ></video>
              </div>
            </div>
          )}

          <!-- Video Player Section (if external videoUrl is present and no local video) -->
          {!post.data.videoFile && embedVideoUrl && (
            <div class="video-section" style="margin-top: 3.5rem;">
              <h2 style="margin-bottom: 1.5rem;">Видео по теме:</h2>
              <div class="video-wrapper">
                <iframe
                  src={embedVideoUrl}
                  title={`Видео: ${post.data.title}`}
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  allowfullscreen
                ></iframe>
              </div>
            </div>
          )}
        </section>
      </article>

      <!-- Right Column: Sidebar -->
      <aside class="sidebar">
        <div class="sidebar-sticky">
          <!-- Widget 1: TOC -->
          <div class="widget" id="toc-widget">
            <h3 class="widget-title">Содержание</h3>
            <ul class="toc-list" id="toc-list">
              <!-- Dynamically populated by client script below -->
            </ul>
          </div>

          <!-- Widget 2: CTA Banner (Blueprint style) -->
          {settings.sidebarBannerTitle && (
            <div class="widget widget-cta">
              <h3 class="widget-cta-title">{settings.sidebarBannerTitle}</h3>
              <p class="widget-cta-text">{settings.sidebarBannerText}</p>
              <button class="btn-cta btn-trigger-estimate" type="button">
                {settings.sidebarBannerButtonText}
              </button>
            </div>
          )}

          <!-- Widget 3: Related Posts -->
          {relatedPosts.length > 0 && (
            <div class="widget">
              <h3 class="widget-title">Похожие статьи</h3>
              <div class="related-list">
                {relatedPosts.map((rp) => (
                  <a href={`/posts/${rp.data.category}/${rp.slug}`} class="related-item">
                    {rp.data.coverImage ? (
                      <img src={rp.data.coverImage} alt={rp.data.title} class="related-thumb" />
                    ) : (
                      <div class="related-thumb" style="background: linear-gradient(135deg, hsl(263, 60%, 20%) 0%, hsl(190, 60%, 20%) 100%);"></div>
                    )}
                    <span class="related-title">{rp.data.title}</span>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </aside>
    </div>
  </main>

  <!-- Estimate Modal -->
  <div class="modal-overlay" id="estimate-modal">
    <div class="modal-card" style="max-width: 460px; text-align: left;">
      <button class="modal-close-x" id="close-estimate-x" type="button">&times;</button>
      <h3 class="modal-title" style="margin-bottom: 0.5rem; font-size: 1.5rem; background: var(--accent-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; font-weight: 800;">Рассчитать смету</h3>
      <p class="modal-text" style="margin-bottom: 1.5rem; font-size: 0.9rem; color: var(--text-secondary);">
        Оставьте контакты, и мы подготовим для вас предварительный расчет стоимости работ и материалов.
      </p>
      
      <form class="contact-form" id="estimate-form">
        <div class="form-group" style="margin-bottom: 1rem;">
          <label class="form-label" for="est-name" style="margin-bottom: 0.4rem;">Ваше имя</label>
          <input class="form-input" type="text" id="est-name" placeholder="Иван" required />
        </div>
        <div class="form-group" style="margin-bottom: 1rem;">
          <label class="form-label" for="est-contact" style="margin-bottom: 0.4rem;">Телефон или Email</label>
          <input class="form-input" type="text" id="est-contact" placeholder="+7 (999) 123-45-67" required />
        </div>
        <div class="form-group" style="margin-bottom: 1.5rem;">
          <label class="form-label" for="est-type" style="margin-bottom: 0.4rem;">Что требуется рассчитать?</label>
          <select class="form-input" id="est-type" style="padding: 0.6rem 0.8rem; background: #fff; cursor: pointer;">
            <option value="Комплексный ремонт">Комплексный ремонт</option>
            <option value="Косметический ремонт">Косметический ремонт</option>
            <option value="Капитальный ремонт">Капитальный ремонт</option>
            <option value="Дизайн-проект интерьера">Дизайн-проект интерьера</option>
            <option value="Сантехнические работы">Сантехнические работы</option>
            <option value="Электромонтажные работы">Электромонтажные работы</option>
          </select>
        </div>
        <button class="btn-submit" type="submit" id="est-submit-btn" style="width: 100%;">
          <span>Отправить запрос</span>
          <svg id="est-loading-spinner" style="display: none; animation: spin 1s linear infinite;" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <line x1="12" y1="2" x2="12" y2="6"></line>
            <line x1="12" y1="18" x2="12" y2="22"></line>
            <line x1="4.93" y1="4.93" x2="7.76" y2="7.76"></line>
            <line x1="16.24" y1="16.24" x2="19.07" y2="19.07"></line>
            <line x1="2" y1="12" x2="6" y2="12"></line>
            <line x1="18" y1="12" x2="22" y2="12"></line>
            <line x1="4.93" y1="19.07" x2="7.76" y2="16.24"></line>
            <line x1="16.24" y1="7.76" x2="19.07" y2="4.93"></line>
          </svg>
        </button>
      </form>
    </div>
  </div>

  <!-- Success Modal -->
  <div class="modal-overlay" id="success-modal">
    <div class="modal-card">
      <div class="modal-icon modal-icon-success">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>
      <h3 class="modal-title">Заявка отправлена!</h3>
      <p class="modal-text">Мы получили ваш запрос на расчет сметы и свяжемся с вами в ближайшее время.</p>
      <button class="btn-modal-close" id="close-modal-btn" type="button">Отлично</button>
    </div>
  </div>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-col">
          <h3 style="margin-top: 0;">{settings.siteName}</h3>
          <p>{settings.siteDescription}</p>
        </div>
        <div class="footer-col">
          <h3>Разделы</h3>
          <ul class="footer-list">
            <li><a href="/">Все статьи</a></li>
            {dbCategories.map(cat => (
              <li><a href={`/#${cat.id}`}>{cat.data.name}</a></li>
            ))}
          </ul>
        </div>
        <div class="footer-col">
          <h3>Контакты</h3>
          <p style="margin-bottom: 0.75rem;">Задайте вопрос или оставьте заявку на консультацию!</p>
          <a href="/#contact" class="btn-cta" style="display: inline-block; width: auto; font-size: 0.85rem; padding: 0.5rem 1rem;">Написать нам</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2026 {settings.siteName}. Все права защищены.</p>
        <div style="display: flex; gap: 1.5rem;">
          <a href="/">Главная</a>
          <a href="/keystatic">Админ-панель</a>
        </div>
      </div>
    </div>
  </footer>

  <!-- Client-side script for dynamic Table of Contents, active highlight, and estimate modal -->
  <script>
    // 1. Table of Contents generation
    const headings = document.querySelectorAll('.article-body h2, .article-body h3');
    const tocList = document.getElementById('toc-list');
    
    if (tocList && headings.length > 0) {
      headings.forEach((heading, index) => {
        // Set unique ID for each heading if it does not exist
        if (!heading.id) {
          heading.id = `section-${index}`;
        }
        
        const li = document.createElement('li');
        li.className = 'toc-item';
        
        const a = document.createElement('a');
        a.href = `#${heading.id}`;
        a.className = heading.tagName.toLowerCase() === 'h3' ? 'toc-link toc-h3' : 'toc-link';
        a.textContent = heading.textContent;
        
        li.appendChild(a);
        tocList.appendChild(li);
      });

      // Highlight active toc link on scroll
      const tocLinks = document.querySelectorAll('.toc-link');
      const observerOptions = {
        root: null,
        rootMargin: '0px 0px -70% 0px', // detects when headers hit top 30% of window
        threshold: 0.1
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            tocLinks.forEach(link => {
              if (link.getAttribute('href') === `#${id}`) {
                link.classList.add('active');
              } else {
                link.classList.remove('active');
              }
            });
          }
        });
      }, observerOptions);

      headings.forEach(heading => observer.observe(heading));
    } else {
      // Hide TOC widget if no H2 or H3 headers are present in the text
      const tocWidget = document.getElementById('toc-widget');
      if (tocWidget) {
        tocWidget.style.display = 'none';
      }
    }

    // 2. Estimate Modal Handling
    const estimateModal = document.getElementById('estimate-modal');
    const openEstimateBtns = document.querySelectorAll('.btn-trigger-estimate');
    const closeEstimateX = document.getElementById('close-estimate-x');
    const estimateForm = document.getElementById('estimate-form');
    const estSubmitBtn = document.getElementById('est-submit-btn');
    const estSpinner = document.getElementById('est-loading-spinner');
    
    const successModal = document.getElementById('success-modal');
    const closeSuccessBtn = document.getElementById('close-modal-btn');

    function openModal() {
      if (estimateModal) estimateModal.classList.add('active');
    }

    function closeModal() {
      if (estimateModal) estimateModal.classList.remove('active');
    }

    openEstimateBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        openModal();
      });
    });

    if (closeEstimateX) {
      closeEstimateX.addEventListener('click', closeModal);
    }

    // Close modal on clicking outside the card
    window.addEventListener('click', (e) => {
      if (e.target === estimateModal) {
        closeModal();
      }
      if (e.target === successModal) {
        if (successModal) successModal.classList.remove('active');
      }
    });

    if (estimateForm) {
      estimateForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        if (estSubmitBtn) (estSubmitBtn as HTMLButtonElement).disabled = true;
        if (estSpinner) (estSpinner as HTMLElement).style.display = 'inline-block';

        const name = (document.getElementById('est-name') as HTMLInputElement).value;
        const contact = (document.getElementById('est-contact') as HTMLInputElement).value;
        const type = (document.getElementById('est-type') as HTMLSelectElement).value;

        try {
          const response = await fetch('/api/contact', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ 
              name, 
              contact, 
              message: `Запрос расчета сметы. Выбранное направление: ${type}` 
            })
          });

          const result = await response.json();

          if (response.ok && result.success) {
            (estimateForm as HTMLFormElement).reset();
            closeModal();
            if (successModal) successModal.classList.add('active');
          } else {
            alert(result.error || 'Произошла ошибка при отправке запроса.');
          }
        } catch (error) {
          console.error('Estimate submit error:', error);
          alert('Не удалось отправить запрос. Проверьте интернет-соединение.');
        } finally {
          if (estSubmitBtn) (estSubmitBtn as HTMLButtonElement).disabled = false;
          if (estSpinner) (estSpinner as HTMLElement).style.display = 'none';
        }
      });
    }

    if (closeSuccessBtn && successModal) {
      closeSuccessBtn.addEventListener('click', () => {
        successModal.classList.remove('active');
      });
    }
  </script>
</body>
</html>
